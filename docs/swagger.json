                },
                "city": {
                    "type": "string",
                    "example": "Moscow"
                },
                "coordinates": {
                    "type": "string",
                    "example": "55.751244,37.618423"
                },
                "country": {
                    "type": "string",
                    "example": "Russia"
                },
                "el1_tariff": {
                    "type": "number",
                    "example": 5.7
                },
                "el2_tariff": {
                    "type": "number",
                    "example": 4.9
                },
                "gvs_tariff": {
                    "type": "number",
                    "example": 189.5
                },
                "house": {
                    "type": "string",
                    "example": "12"
                },
                "hvs_tariff": {
                    "type": "number",
                    "example": 45.2
                },
                "id": {
                    "type": "string",
                    "example": "7c9e6b4a-4321-4a1b-8def-abcdef123456"
                },
                "landlord_id": {
                    "type": "string",
                    "example": "3f7e2b1a-1234-4c56-9abc-1234567890ab"
                },
                "name": {
                    "type": "string",
                    "example": "Sunny Apartment"
                },
                "region": {
