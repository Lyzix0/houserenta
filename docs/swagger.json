                    "example": "Moscow"
                },
                "street": {
                    "type": "string",
                    "example": "Tverskaya"
                }
            }
        },
        "entity.PropertyDetail": {
            "description": "Объект недвижимости с автоматически собранными связанными сущностями: показаниями счетчиков, счетами, будущими начислениями, данными аренды и арендодателя.",
            "type": "object",
            "properties": {
                "apartment": {
                    "type": "string",
                    "example": "45"
                },
                "applications": {
                    "description": "Applications is always empty: there is no applications/tickets subsystem implemented yet.",
                    "type": "array",
                    "items": {}
                },
                "balance": {
                    "type": "number",
                    "example": 1250.75
                },
                "bills": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/entity.Bill"
                    }
                },
                "city": {
                    "type": "string",
                    "example": "Moscow"
                },
                "coordinates": {
                    "type": "string",
                    "example": "55.751244,37.618423"
                },
                "country": {
                    "type": "string",
                    "example": "Russia"
                },
                "customNextItems": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/entity.CustomNextItem"
                    }
                },
                "el1_tariff": {
                    "type": "number",
                    "example": 5.7
                },
                "el2_tariff": {
                    "type": "number",
                    "example": 4.9
                },
                "gvs_tariff": {
                    "type": "number",
                    "example": 189.5
                },
                "house": {
                    "type": "string",
                    "example": "12"
                },
                "hvs_tariff": {
                    "type": "number",
                    "example": 45.2
                },
                "id": {
                    "type": "string",
                    "example": "7c9e6b4a-4321-4a1b-8def-abcdef123456"
                },
                "landlordName": {
                    "type": "string",
                    "example": "Алексей Петров"
                },
                "landlordPhone": {
                    "type": "string",
                    "example": "+79001234567"
                },
                "landlord_id": {
                    "type": "string",
                    "example": "3f7e2b1a-1234-4c56-9abc-1234567890ab"
                },
                "name": {
                    "type": "string",
                    "example": "Sunny Apartment"
                },
                "readings": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/entity.Reading"
                    }
                },
                "region": {
                    "type": "string",
                    "example": "Moscow"
                },
                "street": {
                    "type": "string",
                    "example": "Tverskaya"
                },
                "tenant": {
                    "$ref": "#/definitions/entity.Lease"
                }
            }
        },
