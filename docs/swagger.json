                },
                "country": {
                    "type": "string",
                    "example": "Russia"
                },
                "el1Tariff": {
                    "type": "number",
                    "example": 5.7
                },
                "el2Tariff": {
                    "type": "number",
                    "example": 4.9
                },
                "gvsTariff": {
                    "type": "number",
                    "example": 189.5
                },
                "house": {
                    "type": "string",
                    "example": "12"
                },
                "hvsTariff": {
                    "type": "number",
                    "example": 45.2
                },
                "name": {
                    "type": "string",
                    "example": "Sunny Apartment"
                },
                "region": {
                    "type": "string",
                    "example": "Moscow"
                },
                "street": {
                    "type": "string",
                    "example": "Tverskaya"
                }
