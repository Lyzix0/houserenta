            }
        },
        "request.Profile": {
            "type": "object",
            "properties": {
                "document": {
                    "type": "string",
                    "example": "4510 123456"
                },
                "email": {
                    "type": "string",
                    "example": "newemail@example.com"
                },
                "name": {
                    "type": "string",
                    "maxLength": 100,
                    "minLength": 2,
                    "example": "Ivan Kolesnikov"
                },
                "password": {
                    "type": "string",
                    "minLength": 6,
